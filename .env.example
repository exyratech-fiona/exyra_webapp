# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Keys (optional — for extending features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database (for backend extension)
DATABASE_URL=postgresql://postgres:password@localhost:5432/exyra_db
REDIS_URL=redis://localhost:6379

# Email — Gmail SMTP for contact form
# Use your Gmail address and a Gmail App Password (NOT your real password)
# To generate App Password: myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_USER=exyratech@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature flags
NEXT_PUBLIC_ENABLE_3D=true
NEXT_PUBLIC_ENABLE_CHAT=true
